# Copy to .env and adjust. .env is gitignored.

# ---------------------------------------------------------------------------
# LLM backend selection. Either pick here, or switch at runtime in the UI.
#   LLM_PROVIDER = ollama   -> fully local (default, no API key)
#   LLM_PROVIDER = anthropic-> external Claude API (needs ANTHROPIC_API_KEY)
# ---------------------------------------------------------------------------
LLM_PROVIDER=ollama

# --- Local LLM (Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- External LLM (Anthropic Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Embeddings (local, runs offline) ---
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
EMBEDDING_DIM=768

# --- Optional cross-encoder reranker (article's step 3) ---
RERANK_ENABLED=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Hybrid retrieval tuning (see the InfoQ article) ---
RRF_K=60                 # reciprocal-rank-fusion constant (lower => favours exact matches)
RETRIEVAL_CANDIDATES=50  # candidates pulled from each channel before fusion
RETRIEVAL_TOP_K=5        # final chunks fed to the agents

# --- Debate ---
MAX_DEBATE_ROUNDS=3

# --- Web search fallback (used when the knowledge base has nothing relevant) ---
WEB_SEARCH_ENABLED=true
WEB_SEARCH_RESULTS=6

# --- Postgres / pgvector (matches docker-compose.yml) ---
PGHOST=localhost
PGPORT=5432
PGUSER=agent_user
PGPASSWORD=agent_pass
PGDATABASE=agent_db
